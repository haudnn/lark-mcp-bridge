# ─── Lark / Feishu credentials ─────────────────────────────────────────────
# Get these from https://open.feishu.cn or https://open.larksuite.com
LARK_APP_ID=cli_xxxx
LARK_APP_SECRET=your_app_secret_here

# ─── Domain ─────────────────────────────────────────────────────────────────
# Feishu (China):      https://open.feishu.cn   (default if omitted)
# Lark (international): https://open.larksuite.com
# LARK_DOMAIN=https://open.larksuite.com

# ─── Tool presets ───────────────────────────────────────────────────────────
# Comma-separated preset names or specific tool IDs.
# Available presets: preset.im.default, preset.docx.default, preset.calendar.default
# Leave blank to use lark-mcp defaults.
# LARK_TOOLS=preset.im.default,preset.docx.default

# ─── Bridge server ──────────────────────────────────────────────────────────
# MCP endpoint (owned by lark-mcp):  http://BRIDGE_HOST:BRIDGE_PORT/mcp
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=3000

# Health-check endpoint (owned by this bridge app)
HEALTH_PORT=3001
